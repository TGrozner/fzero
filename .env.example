# Copy to `.env.local` (Vite client env) for local development.
# Production builds get these from Pages project env / GitHub Actions repo vars.

# WebSocket URL the client connects to. In dev the client falls back to
# ws://127.0.0.1:8787/ws automatically when this is empty.
#
# Production examples:
#   VITE_SERVER_URL=wss://neon-drift-server.example.workers.dev/ws
#
# If you'd rather use the same-origin /ws path (handled by functions/ws.ts),
# leave this blank and set WORKER_URL on the Pages project instead.
VITE_SERVER_URL=
